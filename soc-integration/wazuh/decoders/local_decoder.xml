<!-- Sentrix canonical alert JSON. Field extraction is performed only by JSON_Decoder. -->
<decoder name="sentrix">
  <parent>json</parent>
  <prematch type="pcre2">"source"\s*:\s*"sentrix"</prematch>
  <use_own_name>true</use_own_name>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
  <json_null_field>discard</json_null_field>
  <json_array_structure>array</json_array_structure>
</decoder>
